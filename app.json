{
  "expo": {
    "name": "Pupular",
    "slug": "pupular",
    "version": "1.2.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF5757"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "app.pupular",
      "buildNumber": "6",
      "usesAppleSignIn": true,
      "infoPlist": {
        "CFBundleDisplayName": "Pupular",
        "CFBundleName": "Pupular",
        "NSLocationWhenInUseUsageDescription": "Pupular uses your location to find adorable rescue pets near you.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF5757"
      },
      "package": "app.pupular",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "extra": {
      "eas": {
        "projectId": "68e87cbc-9f59-4866-a8bf-d8012dd53076"
      }
    },
    "plugins": [
      "expo-location",
      "expo-apple-authentication"
    ],
    "owner": "jfeuerwashere"
  }
}
